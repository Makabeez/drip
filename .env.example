# ============================================================================
# Drip — Autonomous HL Perps Agent
# ============================================================================
# Copy to .env, fill in real values, NEVER commit .env to git.
# (Your existing .gitignore from AlphaDrip already excludes it.)
# ============================================================================


# ---- AlphaDrip emitter (REUSED from v1, should already be running) ---------

ALPHADRIP_EMITTER=https://alphadrip.baserep.xyz
ALPHADRIP_SELLER=0x9747B4B2F4EcB59C4055c45CDA0Ae0D44A04eD14


# ---- Arc Testnet (signal payment chain) ------------------------------------

ARC_CHAIN_ID=5042002
ARC_RPC=https://rpc.testnet.arc.network
ARC_USDC=0x3600000000000000000000000000000000000000
# Block explorer for tx hash links in dashboard:
ARC_EXPLORER=https://explorer.testnet.arc.network


# ---- Consumer wallet (PAYS for signals on Arc) -----------------------------
# Dedicated wallet, fund with ~1-5 USDC on Arc Testnet.
# At $0.003 per signal that buys 333-1666 signals.

CONSUMER_PK=                    # 0x... private key, 64 hex chars
SIGNAL_PRICE_MICROS=3000        # $0.003 in USDC micros (matches emitter)


# ---- Hyperliquid (TRADES) --------------------------------------------------
# Use API wallet, NOT master key. API wallet has trade-only permission.
# Generate at https://app.hyperliquid.xyz/API

HL_API_WALLET_PK=               # 0x... private key of API wallet
HL_MASTER_ADDRESS=              # 0x... public address of the MAIN account
                                # (NOT the API wallet — see SDK docs)
HL_NETWORK=testnet              # testnet | mainnet  (D1-D9 testnet, D10 → mainnet)
HL_SYMBOL=BTC                   # LOCKED: BTC-PERP only for v1
HL_MIN_NOTIONAL=10              # $ — HL absolute minimum, do not lower
HL_MAINNET_MARGIN_USD=50        # LOCKED: $50 mainnet allocation for D10 switch


# ---- Risk parameters (lifted from your hl-signal-bot proven config) --------

RISK_TP_PCT=0.0012              # +0.12% take-profit
RISK_SL_PCT=0.0008              # -0.08% stop-loss
RISK_TIME_STOP_SECONDS=60       # close if open > 60s regardless of PnL
RISK_MAX_LEVERAGE=5             # absolute cap, never exceed
RISK_DAILY_LOSS_PCT=0.02        # -2% NAV daily → kill switch 24h halt
RISK_LIQ_MARGIN_RATIO=0.40      # marginUsed/accountValue threshold → auto-deleverage
RISK_KELLY_FRACTION=0.25        # 0.25 = quarter-Kelly, conservative
RISK_MAX_POSITION_PCT=0.05      # 5% NAV max per single trade


# ---- USYC idle margin sweep -----------------------------------------------
# When free margin > 2x max open margin for 5 consecutive checks,
# park 70% of excess in USYC for yield.

USYC_ENABLED=true
USYC_SWEEP_RATIO=0.70
USYC_TRIGGER_CHECKS=5
USYC_CONTRACT=                  # fill from Circle docs once on chosen network


# ---- CCTP V2 (Arc → HL Arbitrum margin top-up) -----------------------------

CCTP_ENABLED=true
CCTP_TOP_UP_USDC=50             # top up margin by 50 USDC when triggered
CCTP_TRIGGER_MARGIN_USDC=20     # if HL free margin < 20 USDC → top up


# ---- Telegram (alerts via Makaclaw bot) ------------------------------------
# LOCKED: reusing Makaclaw — your existing 24/7 bot on the droplet.
# Risk Manager alerts route through Makaclaw's existing send_message pathway.

TG_BOT_TOKEN=                   # reuse Makaclaw's token (same droplet, same chat)
TG_CHAT_ID=                     # your private chat with Makaclaw
TG_ALERT_PREFIX=🤖 DRIP         # Prefix every Drip alert so they're scannable
                                # among Makaclaw's normal audit stream


# ---- Reasoning trace (Agora research item #1 hook) ------------------------
# LOCKED: enabled. Every decision logged with structured reasoning.
# Hashable, replayable, sets up post-hackathon "reasoning marketplace" angle.

REASONING_TRACE_ENABLED=true
REASONING_TRACE_SCHEMA_VERSION=1
REASONING_TRACE_HASH_ALGO=sha256
# Optional: pin daily trace bundle to Irys post-D11.
REASONING_TRACE_PIN_IRYS=false


# ---- Process / ops ---------------------------------------------------------

LOG_LEVEL=INFO
SQLITE_PATH=./data/drip.sqlite
STATE_PORT=8086                 # /state endpoint for dashboard
DASHBOARD_ORIGIN=https://drip.baserep.xyz
